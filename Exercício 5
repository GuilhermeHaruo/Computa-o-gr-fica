#include <GL/glut.h>

float posX = 0.0f, posY = 0.0f, tamanho = 0.2f;
float r = 1.0f, g = 1.0f, b = 1.0f;

void display() {
    glClear(GL_COLOR_BUFFER_BIT);
    glBegin(GL_QUADS); // ISSO DESENHA O QUADRADO
        glColor3f(r, g, b);
        glVertex2f(posX - tamanho, posY - tamanho);
        glVertex2f(posX + tamanho, posY - tamanho);
        glVertex2f(posX + tamanho, posY + tamanho);
        glVertex2f(posX - tamanho, posY + tamanho);
    glEnd();
    glutSwapBuffers();
}

void teclado(unsigned char key, int x, int y) {
    if (key == '1') { r = 1.0f; g = 0.0f; b = 0.0f; }
    if (key == '2') { r = 0.0f; g = 1.0f; b = 0.0f; }
    if (key == '3') { r = 0.0f; g = 0.0f; b = 1.0f; }
    glutPostRedisplay();
}

void teclasEspeciais(int key, int x, int y) {
    float vel = 0.05f;
    if (key == GLUT_KEY_UP && posY + tamanho < 1.0f)    posY += vel;
    if (key == GLUT_KEY_DOWN && posY - tamanho > -1.0f)  posY -= vel;
    if (key == GLUT_KEY_LEFT && posX - tamanho > -1.0f)  posX -= vel;
    if (key == GLUT_KEY_RIGHT && posX + tamanho < 1.0f) posX += vel;
    glutPostRedisplay();
}

int main(int argc, char** argv) {
    glutInit(&argc, argv);
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB);
    glutInitWindowSize(800, 600);
    glutCreateWindow("Exercicio 4: Agora e um Quadrado");
    glClearColor(0.2f, 0.2f, 0.2f, 1.0f);
    glutDisplayFunc(display);
    glutKeyboardFunc(teclado);
    glutSpecialFunc(teclasEspeciais);
    glutMainLoop();
    return 0;
}
